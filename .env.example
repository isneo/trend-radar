# Copy to .env.local and fill in actual values.
# .env.local is gitignored.

# ---------- Telegram ----------
# Create via @BotFather on Telegram, then paste token here.
TELEGRAM_BOT_TOKEN=

# ---------- Postgres ----------
POSTGRES_USER=trendradar
POSTGRES_PASSWORD=trendradar_dev
POSTGRES_DB=trendradar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy async URL (used by FastAPI / bot / worker)
DATABASE_URL=postgresql+asyncpg://trendradar:trendradar_dev@localhost:5432/trendradar

# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg://trendradar:trendradar_dev@localhost:5432/trendradar

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- App ----------
APP_ENV=local
LOG_LEVEL=INFO
